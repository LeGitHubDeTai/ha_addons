#!/usr/bin/with-contenv bashio
# Nginx service for Home Assistant Ingress

set -e

# Debug output
echo "[DEBUG] Nginx service script starting..."
echo "[DEBUG] Checking bashio availability..."
type bashio || echo "[DEBUG] bashio not found in PATH"

bashio::log.info "Waiting for Gitea to be ready on port 3000..."

# Wait for Gitea to be ready on port 3000 (using bash built-in)
while ! bash -c "exec 3<> /dev/tcp/localhost/3000" 2>/dev/null; do
    bashio::log.info "Gitea not ready yet, waiting..."
    sleep 2
done

bashio::log.info "Gitea is ready on port 3000, starting Nginx..."

# Ensure nginx config directory exists
mkdir -p /var/log/nginx /var/cache/nginx

# Test nginx configuration
if ! nginx -t 2>&1; then
    bashio::log.error "Nginx configuration test failed!"
    exit 1
fi

bashio::log.info "Nginx config OK, starting service on port 8099..."

# Start Nginx
exec nginx -g 'daemon off;'
